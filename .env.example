# Токен Telegram-бота от @BotFather (обязательно)
BOT_TOKEN=

# Ключ Anthropic (ОПЦИОНАЛЬНО).
# Пусто → бот работает на встроенном FAQ-движке, бесплатно, демо не падает.
# Задан → Claude отвечает живым языком строго по базе знаний салона.
ANTHROPIC_API_KEY=

# Модель. Дёшево и быстро под поток ресепшена — claude-haiku-4-5.
# Для максимального качества можно поставить claude-opus-4-8.
MODEL_ID=claude-haiku-4-5

# Chat ID администратора для уведомлений о заявках (узнать у @userinfobot).
# Пусто → заявки пишутся в лог.
OWNER_CHAT_ID=

# Необязательно: свой путь к базе знаний
# KB_PATH=data/salon.json
